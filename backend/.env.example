# Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/anjali_alankaram?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_ACCESS_EXPIRES="15m"

# AWS S3 (Uploads)
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="anjali-alankaram-assets"

# MSG91 (OTP)
MSG91_AUTH_KEY="your_msg91_auth_key"
MSG91_TEMPLATE_ID="your_template_id"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# Shiprocket
SHIPROCKET_EMAIL="your_email@example.com"
SHIPROCKET_PASSWORD="your_shiprocket_password"

# Firebase (Push Notifications)
FIREBASE_SERVICE_ACCOUNT_BASE64="base64_encoded_service_account_json"

# Rate Limiting
RATE_LIMIT_REQUESTS=100

# OpenAI (AI Product Image Generation)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# CloudFront (for serving assets via CDN)
CLOUDFRONT_DOMAIN="your-distribution-id.cloudfront.net"

# AWS SQS Queue URL for background AI generation workers
AWS_SQS_QUEUE_URL="https://sqs.ap-south-2.amazonaws.com/123456789/anjali-alankaram-ai-images"

# Upload Driver: 's3' for production, 'local' for development
UPLOAD_DRIVER=s3

