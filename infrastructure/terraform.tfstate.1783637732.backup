    {
      "mode": "managed",
      "type": "aws_cloudfront_function",
      "name": "security_headers",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:cloudfront::908027403766:function/anjali-alankaram-security-headers",
            "code": "function handler(event) {\n    var response = event.response;\n    var headers = response.headers;\n\n    // Strict Transport Security (HSTS)\n    headers['strict-transport-security'] = { value: 'max-age=63072000; includeSubDomains; preload' };\n    \n    // XSS Protection\n    headers['x-xss-protection'] = { value: '1; mode=block' };\n    \n    // Prevent Clickjacking\n    headers['x-frame-options'] = { value: 'SAMEORIGIN' };\n    \n    // Content Type Options\n    headers['x-content-type-options'] = { value: 'nosniff' };\n    \n    // Referrer Policy\n    headers['referrer-policy'] = { value: 'strict-origin-when-cross-origin' };\n\n    // Content Security Policy (CSP)\n    headers['content-security-policy'] = {\n        value: \"default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://checkout.razorpay.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://*.cloudfront.net https://*.amazonaws.com; connect-src 'self' https://api.openai.com https://checkout.razorpay.com https://www.google-analytics.com; frame-src 'self' https://api.razorpay.com https://checkout.razorpay.com;\"\n    };\n\n    return response;\n}\n",
            "comment": "Injects HSTS, CSP, and security headers at the edge",
            "etag": "ETVPDKIKX0DER",
            "id": "anjali-alankaram-security-headers",
            "key_value_store_associations": [],
            "live_stage_etag": "ETVPDKIKX0DER",
            "name": "anjali-alankaram-security-headers",
            "publish": true,
            "runtime": "cloudfront-js-1.0",
            "status": "DEPLOYED"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        }
      ]
    },
